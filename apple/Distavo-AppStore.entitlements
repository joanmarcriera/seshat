<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Mac App Store edition: App Sandbox + the minimum access Distavo needs. -->
  <key>com.apple.security.app-sandbox</key>
  <true/>
  <!-- Talk to the user's WhisperX/Ollama servers. -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- Read recordings / write notes in user-chosen folders (via NSOpenPanel +
       security-scoped bookmarks). -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
  <!-- Persist that access across launches: required to create/resolve the
       app-scoped security-scoped bookmarks in SandboxFolders.swift. Without it
       bookmarkData(.withSecurityScope) throws and the login watcher re-prompts
       for both folders on every launch. -->
  <key>com.apple.security.files.bookmarks.app-scope</key>
  <true/>
</dict>
</plist>
